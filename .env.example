# ── Red Thread Server ───────────────────────────────────────────────────
PORT=4000
MONGODB_URI=mongodb://localhost:27017/red-thread

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

NODE_ENV=development

# ── Production example (e.g. Render / Railway) ──────────────────────────
# PORT=4000
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/red-thread
# ALLOWED_ORIGINS=https://noori.yourdomain.com,https://sahilos.yourdomain.com
# NODE_ENV=production
